{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "Calori Life",
    "version": "1.0.0",
    "language": "he",
    "direction": "rtl",
    "inspiration": ["24me", "Apple Health", "Notion"],
    "northStar": "Quiet by default. Loud when it matters."
  },
  "color": {
    "brand": {
      "nutrition": {
        "primary":   { "value": "#059669", "type": "color", "description": "Meals, FAB, active nav, today, primary CTA" },
        "secondary": { "value": "#10B981", "type": "color" },
        "soft":      { "value": "#D1FAE5", "type": "color", "description": "Tints, chips, focus ring" }
      },
      "fitness": {
        "primary":   { "value": "#7C3AED", "type": "color", "description": "Workouts, pomodoro accent" },
        "secondary": { "value": "#8B5CF6", "type": "color" },
        "soft":      { "value": "#EDE9FE", "type": "color" }
      }
    },
    "neutral": {
      "canvas":   { "value": "#F5F5F7" },
      "surface":  { "value": "#FFFFFF" },
      "ink":      { "value": "#1D1D1F" },
      "inkSoft":  { "value": "#6B7280" },
      "hairline": { "value": "#E5E7EB" }
    },
    "neutralDark": {
      "canvas":   { "value": "#0B0B0D" },
      "surface":  { "value": "#17171A" },
      "ink":      { "value": "#F5F5F7" },
      "inkSoft":  { "value": "#9CA3AF" },
      "hairline": { "value": "#26262B" }
    },
    "semantic": {
      "info":    { "value": "#3B82F6", "description": "Lecture / tutorial accents" },
      "warning": { "value": "#F59E0B", "description": "Notes accent, due-soon" },
      "danger":  { "value": "#EF4444", "description": "Exam flood, destructive" },
      "success": { "value": "#10B981" }
    },
    "itemType": {
      "studyEvent":    { "card": "surface", "accent": "info",           "text": "ink",     "style": "border-start-4" },
      "personalEvent": { "card": "surface", "accent": "inkSoft",        "text": "ink",     "style": "border-start-4" },
      "exam":          { "card": "danger",  "accent": null,             "text": "#FFFFFF", "style": "flood" },
      "caloriMeal":    { "card": "nutrition.primary", "accent": null,   "text": "#FFFFFF", "style": "flood" },
      "caloriWorkout": { "card": "fitness.primary",   "accent": null,   "text": "#FFFFFF", "style": "flood" },
      "note":          { "card": "surface", "accent": "warning",        "text": "ink",     "style": "border-start-4" },
      "pomodoro":      { "card": "surface", "accent": "fitness.soft",   "text": "ink",     "style": "icon-chip" },
      "personalTask":  { "card": "surface", "accent": "priorityDot",    "text": "ink",     "style": "checkbox" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans":    { "value": "-apple-system, 'SF Pro Text', 'Heebo', system-ui, sans-serif" },
      "display": { "value": "'SF Pro Display', 'Heebo', system-ui, sans-serif" }
    },
    "fontSize": {
      "12": { "value": "12px", "lineHeight": "16px", "role": "caption" },
      "13": { "value": "13px", "lineHeight": "18px", "role": "meta" },
      "14": { "value": "14px", "lineHeight": "20px", "role": "body" },
      "16": { "value": "16px", "lineHeight": "24px", "role": "body-lg" },
      "18": { "value": "18px", "lineHeight": "26px", "role": "subtitle" },
      "22": { "value": "22px", "lineHeight": "28px", "role": "title" },
      "28": { "value": "28px", "lineHeight": "34px", "role": "h1" },
      "34": { "value": "34px", "lineHeight": "40px", "role": "hero" }
    },
    "fontWeight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 },
      "bold":     { "value": 700 }
    }
  },
  "spacing": {
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "12": { "value": "48px" }
  },
  "radius": {
    "sm":   { "value": "8px" },
    "md":   { "value": "12px" },
    "lg":   { "value": "16px" },
    "xl":   { "value": "20px" },
    "pill": { "value": "999px" }
  },
  "shadow": {
    "card":  { "value": "0 1px 2px rgba(0,0,0,.04), 0 4px 12px rgba(0,0,0,.04)" },
    "sheet": { "value": "0 -8px 24px rgba(0,0,0,.08)" },
    "focus": { "value": "0 0 0 3px #D1FAE5" }
  },
  "motion": {
    "easing": {
      "easeOut": { "value": "cubic-bezier(0.16, 1, 0.3, 1)" }
    },
    "duration": {
      "fast": { "value": "140ms" },
      "base": { "value": "180ms" },
      "slow": { "value": "220ms" }
    },
    "spring": {
      "sheet": { "stiffness": 380, "damping": 32 },
      "tap":   { "stiffness": 500, "damping": 30 }
    }
  },
  "layout": {
    "viewport": {
      "mobile":  { "width": 390, "height": 844 },
      "tablet":  { "width": 768 },
      "desktop": { "width": 1280, "contentMax": 1120 }
    },
    "grid": {
      "mobile":  { "columns": 8,  "gutter": 16 },
      "tablet":  { "columns": 12, "gutter": 24 },
      "desktop": { "columns": 12, "gutter": 32 }
    },
    "bottomNav": { "height": 64 },
    "fab":       { "size": 56, "raise": 8 },
    "touchTargetMin": 44
  },
  "component": {
    "button": {
      "sizes": { "sm": 32, "md": 40, "lg": 48 },
      "variants": ["primary", "secondary", "ghost", "destructive"],
      "pressedScale": 0.97
    },
    "input":    { "height": 44, "radius": "md", "focusRing": "shadow.focus" },
    "checkbox": { "size": 22, "shape": "round", "checkedFill": "brand.nutrition.primary" },
    "switch":   { "trackWidth": 51, "trackHeight": 31, "onColor": "brand.nutrition.primary" },
    "chip":     { "height": 28, "radius": "pill", "paddingX": 12 },
    "card":     { "radius": "lg", "padding": 16, "shadow": "card" },
    "listRow":  { "minHeight": 56 },
    "bottomSheet": {
      "dragHandle": { "width": 36, "height": 4, "color": "hairline" },
      "snapPoints": ["40vh", "92vh"],
      "scrim": "rgba(0,0,0,.4)"
    }
  },
  "a11y": {
    "minContrast": "AA",
    "verified": {
      "white_on_nutritionPrimary": 4.52,
      "white_on_fitnessPrimary":   5.93,
      "white_on_danger":           4.00
    },
    "honorReducedMotion": true
  }
}
