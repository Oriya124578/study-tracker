{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "Calori Life",
    "version": "2.0.0",
    "language": "he",
    "direction": "rtl",
    "inspiration": ["Craft", "Things 3", "Notion", "Apple Health", "premium stationery"],
    "northStar": "Editorial · warm · scholarly. Like a beautifully-printed journal that happens to know you.",
    "canonicalReferences": {
      "home":     "inst-2-studies.html (token system + Combo-B layout)",
      "calendar": "inst-1-calendar.html",
      "studies":  "inst-2-studies.html",
      "tasks":    "inst-3-tasks.html",
      "calori":   "inst-4-calori.html",
      "pomodoro": "inst-5-pomodoro.html",
      "home_layout": "combo-B-style3-cream.html"
    }
  },
  "color": {
    "brand": {
      "nutrition": {
        "primary":      { "value": "#059669", "type": "color", "description": "Meals, FAB shadow, active nav, primary CTA, accent italics" },
        "primaryDeep":  { "value": "#065F46", "type": "color", "description": "Avatar, FAB body, deep accents, header on green zones" },
        "secondary":    { "value": "#10B981", "type": "color" },
        "tertiary":     { "value": "#047857", "type": "color", "description": "Mid stop in green gradients" },
        "soft":         { "value": "#F0FDF4", "type": "color", "description": "Light tints, chip backgrounds, focus ring" },
        "softer":       { "value": "#ECFDF5", "type": "color", "description": "Lightest tints for macro chips" }
      },
      "fitness": {
        "primary":   { "value": "#7C3AED", "type": "color", "description": "Workouts, pomodoro flood" },
        "secondary": { "value": "#8B5CF6", "type": "color" },
        "soft":      { "value": "#F3EFFB", "type": "color" },
        "softer":    { "value": "#EDE9FE", "type": "color" }
      }
    },
    "neutral": {
      "canvas":   { "value": "#FAF7F2", "description": "Warm cream — the entire screen background" },
      "surface":  { "value": "#FFFFFF", "description": "Cards and elevated surfaces" },
      "ink":      { "value": "#2A1A0A", "description": "Warm dark brown — primary text" },
      "inkSoft":  { "value": "#8A7A6A", "description": "Warm muted — secondary text, labels, meta" },
      "hairline": { "value": "rgba(180,140,80,.14)", "description": "Borders & dividers — warm low-opacity gold" },
      "hairlineSoft": { "value": "rgba(180,140,80,.10)", "description": "Inner dividers within cards" },
      "tintWarm": { "value": "#F5F0E8", "description": "Segmented control track, hover backgrounds" }
    },
    "neutralDark": {
      "canvas":   { "value": "#1A140E", "description": "Warm-toned dark mode background" },
      "surface":  { "value": "#241B12", "description": "Cards in dark mode" },
      "ink":      { "value": "#FAF7F2", "description": "Text in dark mode" },
      "inkSoft":  { "value": "#A89888", "description": "Secondary text in dark mode" },
      "hairline": { "value": "rgba(180,140,80,.18)" }
    },
    "semantic": {
      "info":         { "value": "#2563EB", "description": "Study events (lectures/tutorials), course-blue accents" },
      "infoSoft":     { "value": "#EFF6FF", "description": "Study event card background" },
      "infoDeep":     { "value": "#1E40AF", "description": "Study event text" },
      "warning":      { "value": "#D97706", "description": "Notes accent, due-soon, carbs macro" },
      "warningSoft":  { "value": "#FFFBEB" },
      "warningDeep":  { "value": "#92400E" },
      "danger":       { "value": "#EF4444", "description": "Exam flood, destructive" },
      "dangerSoft":   { "value": "#FEF2F2", "description": "Exam reminder card background" },
      "dangerDeep":   { "value": "#991B1B", "description": "Exam text" },
      "dangerStrong": { "value": "#DC2626", "description": "Overdue tasks, fats macro" },
      "success":      { "value": "#10B981" }
    },
    "logoGradient": {
      "description": "Exact 4-stop gradient used in /logo.svg outline + on hero card top border. Use these as the canonical brand spectrum.",
      "stops": [
        { "offset": "0%",   "value": "#065F46", "role": "nutrition.primaryDeep" },
        { "offset": "50%",  "value": "#059669", "role": "nutrition.primary" },
        { "offset": "100%", "value": "#047857", "role": "nutrition.tertiary" }
      ],
      "fullSpectrum": {
        "description": "Optional 4-stop full-brand gradient for the wordmark or app icon only — NOT for general accents.",
        "stops": [
          { "offset": "0%",   "value": "#10B981" },
          { "offset": "35%",  "value": "#059669" },
          { "offset": "65%",  "value": "#2563EB" },
          { "offset": "100%", "value": "#7C3AED" }
        ]
      },
      "direction": "linear-gradient(90deg, ...) for card top borders; 135deg for logo"
    },
    "itemType": {
      "description": "The single most important rule — every item across the app uses these colors.",
      "studyEvent":    { "card": "infoSoft",         "border": "info",     "text": "infoDeep",   "style": "soft-bg + border" },
      "personalEvent": { "card": "surface",          "border": "hairline", "text": "ink",        "style": "border-start-3" },
      "exam":          { "card": "dangerSoft",       "border": "danger",   "text": "dangerDeep", "style": "soft-bg + border", "iconBg": "danger" },
      "caloriMeal":    { "card": "nutrition.primary", "border": null,      "text": "#FFFFFF",    "style": "flood" },
      "caloriWorkout": { "card": "fitness.primary",  "border": null,       "text": "#FFFFFF",    "style": "flood" },
      "note":          { "card": "warningSoft",      "border": "warning",  "text": "warningDeep", "style": "soft-bg + border" },
      "pomodoro":      { "card": "surface",          "accent": "fitness.softer", "text": "ink",  "style": "icon-chip" },
      "personalTask":  { "card": "surface",          "accent": "priorityDot",    "text": "ink",  "style": "checkbox-row" }
    }
  },
  "typography": {
    "system": {
      "description": "Three-font system. Display & numbers in Fraunces 600 (characterful variable serif). Headings & accents in Instrument Serif (italic-leaning). Body & UI in Inter. Hebrew falls back to Rubik.",
      "googleFontsImport": "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600;1,9..144,700&family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700;800&family=Rubik:wght@400;500;600;700;800&display=swap"
    },
    "fontFamily": {
      "display":  { "value": "'Instrument Serif', 'Rubik', serif",   "description": "Headings, page titles, hero greetings — including italic accents" },
      "numbers":  { "value": "'Fraunces', 'Rubik', serif",            "description": "ALL numbers: calories, weights, days-to-exam, timer digits, stat values, day-of-month",
                    "weight": 600,
                    "variationSettings": "'opsz' 144, 'SOFT' 0, 'WONK' 0",
                    "letterSpacing": "-0.04em" },
      "body":     { "value": "'Inter', 'Rubik', sans-serif",          "description": "Body text, UI labels, descriptions" },
      "hebrewFallback": { "value": "'Rubik', sans-serif", "description": "All Hebrew text rendered via Rubik (acts as fallback in every stack)" }
    },
    "fontSize": {
      "10": { "value": "10px", "lineHeight": "14px", "role": "eyebrow / uppercase label" },
      "11": { "value": "11px", "lineHeight": "16px", "role": "chip / meta" },
      "12": { "value": "12px", "lineHeight": "18px", "role": "secondary body" },
      "13": { "value": "13px", "lineHeight": "20px", "role": "primary body" },
      "14": { "value": "14px", "lineHeight": "20px", "role": "body-lg" },
      "16": { "value": "16px", "lineHeight": "22px", "role": "list title" },
      "18": { "value": "18px", "lineHeight": "24px", "role": "card title (serif)" },
      "22": { "value": "22px", "lineHeight": "26px", "role": "section title (serif)" },
      "27": { "value": "27px", "lineHeight": "30px", "role": "hero greeting" },
      "32": { "value": "32px", "lineHeight": "34px", "role": "page hero" },
      "42": { "value": "42px", "lineHeight": "40px", "role": "calendar month" },
      "64": { "value": "64px", "lineHeight": "60px", "role": "Calori calories number" },
      "78": { "value": "78px", "lineHeight": "70px", "role": "Pomodoro timer" }
    },
    "fontWeight": {
      "displayRegular": { "value": 400, "appliesTo": "Instrument Serif" },
      "numberStrong":   { "value": 600, "appliesTo": "Fraunces" },
      "numberHero":     { "value": 700, "appliesTo": "Fraunces — today's day-number, primary FAB-adjacent numbers" },
      "bodyRegular":    { "value": 400, "appliesTo": "Inter" },
      "bodyMedium":     { "value": 500 },
      "bodySemibold":   { "value": 600 },
      "bodyBold":       { "value": 700 }
    },
    "italicAccent": {
      "description": "Italic is part of the brand. Always pair with green accent color for the 'editorial pull-quote' effect: <em> tags become green italic. Use sparingly — 1-2 italic words per heading max.",
      "color": "#059669",
      "fontStyle": "italic",
      "appliesTo": "Headings, hero greetings, segment names ('היום', 'בוקר', 'ערב'), data values where appropriate"
    },
    "letterSpacing": {
      "headingTight": "-0.04em",
      "headingDefault": "-0.03em",
      "headingLoose": "-0.02em",
      "labelWide": "0.14em",
      "labelExtraWide": "0.16em"
    },
    "tabularNumbers": {
      "description": "Use font-feature-settings: 'tnum' 1 on lists with stacked numbers (timeline times, dates).",
      "appliesTo": [".t-tm", ".m-time", ".w-time", ".t-due"]
    }
  },
  "spacing": {
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "12": { "value": "48px" }
  },
  "radius": {
    "sm":   { "value": "8px",  "appliesTo": "macro chips, small badges" },
    "md":   { "value": "12px", "appliesTo": "list rows, small cards" },
    "lg":   { "value": "16px", "appliesTo": "stat cards, mini tiles" },
    "xl":   { "value": "18px", "appliesTo": "course cards, sub-cards" },
    "2xl":  { "value": "22px", "appliesTo": "hero card (greeting + nutrition merged)" },
    "3xl":  { "value": "26px", "appliesTo": "section heroes" },
    "pill": { "value": "999px" }
  },
  "shadow": {
    "card":     { "value": "0 4px 24px rgba(40,20,0,.07)", "description": "Hero/main cards — warm shadow" },
    "cardSubtle": { "value": "0 2px 10px rgba(40,20,0,.05)", "description": "Mini tiles & secondary cards" },
    "cardInner":  { "value": "0 1px 0 rgba(255,255,255,.8) inset", "description": "Subtle inner highlight on cream cards" },
    "fabGreen":   { "value": "0 6px 20px rgba(6,95,70,.35)", "description": "Floating action button — warm green" },
    "qaPrimary":  { "value": "0 4px 16px rgba(5,150,105,.28)", "description": "Primary QA pill / button" },
    "sheet":      { "value": "0 -8px 24px rgba(40,20,0,.08)" },
    "phone":      { "value": "0 40px 80px rgba(40,20,0,.2), 0 0 0 1.5px rgba(180,140,80,.15)", "description": "Used in preview HTML — outer phone bezel" },
    "focus":      { "value": "0 0 0 3px #F0FDF4" }
  },
  "motion": {
    "easing":   { "easeOut": { "value": "cubic-bezier(0.16, 1, 0.3, 1)" } },
    "duration": {
      "fast": { "value": "140ms" },
      "base": { "value": "180ms" },
      "slow": { "value": "220ms" }
    },
    "spring": {
      "sheet": { "stiffness": 380, "damping": 32 },
      "tap":   { "stiffness": 500, "damping": 30 }
    }
  },
  "layout": {
    "viewport": {
      "mobile":  { "width": 390, "height": 844 },
      "tablet":  { "width": 768 },
      "desktop": { "width": 1280, "contentMax": 1120 }
    },
    "grid": {
      "mobile":  { "columns": 8,  "gutter": 16 },
      "tablet":  { "columns": 12, "gutter": 24 },
      "desktop": { "columns": 12, "gutter": 32 }
    },
    "screenPadding": { "value": "14px 14px 0", "description": "Edge padding for screen content (inside the phone)" },
    "sectionGap":    { "value": "12px",        "description": "Vertical rhythm between cards" },
    "bottomNav":     { "height": 72, "padding": "0 8px 8px" },
    "fab":           { "size": 52, "position": "bottom-left", "offset": { "left": 20, "bottom": 88 } },
    "touchTargetMin": 44,
    "heroCard": {
      "description": "The signature Combo-B hero card. Greeting + nutrition merged.",
      "background": "surface",
      "borderRadius": "2xl",
      "border": "1px solid hairline",
      "shadow": "card",
      "padding": "20px 18px 18px",
      "topAccentLine": "3px linear-gradient(90deg, #065F46, #059669 50%, #047857)",
      "innerDivider": "1px solid hairlineSoft",
      "structure": "greeting+badge row → divider → stats row (3 cols) + macros + ring"
    }
  },
  "component": {
    "wordmark": {
      "description": "'calori life' — Inter 'calori' + Instrument Serif italic ' life' in green",
      "fontSize": 15,
      "calori": { "font": "Inter", "weight": 700, "color": "ink" },
      "life":   { "font": "Instrument Serif", "weight": 400, "style": "italic", "color": "nutrition.primary", "fontSize": 17 }
    },
    "headerTitle": {
      "description": "Page name in header (e.g. 'בית', 'לימודים', 'משימות')",
      "font": "Instrument Serif",
      "weight": 400,
      "fontSize": 22,
      "color": "ink"
    },
    "heroGreeting": {
      "description": "'ערב טוב, אוריה 👋' — the signature greeting block",
      "font": "Instrument Serif",
      "weight": 400,
      "fontSize": 27,
      "color": "ink",
      "letterSpacing": "-0.04em",
      "italicAccentName": true,
      "italicNameColor": "nutrition.primary"
    },
    "bigNumber": {
      "description": "Hero numbers: 398 (Calori), 14:23 (Pomodoro), 30 (countdowns)",
      "font": "Fraunces",
      "weight": 600,
      "fontStyle": "italic",
      "letterSpacing": "-0.04em",
      "variationSettings": "'opsz' 144, 'SOFT' 0, 'WONK' 0",
      "smallSizes": { "stat": 24, "mini": 24, "midStat": 28 },
      "heroSizes":  { "calori": 64, "pomodoro": 78 }
    },
    "card": {
      "background": "surface",
      "radius": "xl",
      "border": "1px solid hairline",
      "shadow": "cardSubtle",
      "padding": "14px"
    },
    "heroCard": { "radius": "2xl", "shadow": "card", "padding": "20px 18px", "topAccent": "logoGradient" },
    "miniTile": { "radius": "lg", "padding": "13px 12px", "background": "surface", "border": "1px solid hairline" },
    "chip": {
      "height": 28,
      "radius": "sm",
      "paddingX": 10,
      "fontSize": 11,
      "fontWeight": 700,
      "variants": {
        "green":  { "bg": "nutrition.softer", "color": "nutrition.primaryDeep", "border": "1px solid rgba(5,150,105,.15)" },
        "amber":  { "bg": "warningSoft",      "color": "warning",               "border": "1px solid rgba(217,119,6,.15)" },
        "red":    { "bg": "dangerSoft",       "color": "dangerStrong",          "border": "1px solid rgba(220,38,38,.12)" },
        "blue":   { "bg": "infoSoft",         "color": "infoDeep",              "border": "1px solid rgba(37,99,235,.15)" }
      }
    },
    "qaPill": {
      "description": "Quick Action pill in horizontal scroll",
      "radius": 14,
      "padding": "11px 16px",
      "variants": {
        "primary":   { "bg": "nutrition.primary", "text": "#FFFFFF",  "shadow": "qaPrimary" },
        "secondary": { "bg": "surface", "text": "ink", "border": "1px solid rgba(180,140,80,.18)", "shadow": "cardSubtle" }
      }
    },
    "fab": {
      "size": 52,
      "shape": "circle",
      "background": "nutrition.primaryDeep",
      "color": "#FFFFFF",
      "fontSize": 26,
      "fontWeight": 200,
      "shadow": "fabGreen",
      "position": "bottom-left (RTL = visually right)",
      "offset": { "left": "20px", "bottom": "88px" }
    },
    "bottomNav": {
      "height": 72,
      "background": "rgba(250,247,242,.96)",
      "backdropBlur": 20,
      "borderTop": "1px solid hairline",
      "items": 4,
      "itemNames": ["המנהל האישי (Bot)", "בית (Home, active)", "לימודים (BookOpen)", "פוקוס (Target)"],
      "active": { "iconOpacity": 1, "labelColor": "nutrition.primary" },
      "inactive": { "iconOpacity": 0.25, "labelColor": "rgba(42,26,10,.3)" }
    },
    "checkbox": { "size": 22, "shape": "round", "border": "1.5px solid rgba(5,150,105,.4)", "checkedFill": "nutrition.primary" },
    "switch":   { "trackWidth": 51, "trackHeight": 31, "onColor": "nutrition.primary" },
    "input":    { "height": 44, "radius": "md", "border": "1.5px solid rgba(5,150,105,.18)", "background": "surface" },
    "listRow":  { "minHeight": 56 },
    "bottomSheet": {
      "dragHandle": { "width": 36, "height": 4, "color": "hairline" },
      "snapPoints": ["40vh", "92vh"],
      "scrim": "rgba(40,20,0,.4)"
    },
    "phoneFrame": {
      "description": "Used in preview HTML only — for design-brief mockups",
      "width": 390,
      "height": 844,
      "borderRadius": 50,
      "background": "canvas",
      "notch": { "width": 126, "height": 34, "color": "ink", "borderRadius": 20 },
      "boxShadow": "shadow.phone"
    },
    "ring": {
      "description": "Apple-Watch-style double progress ring used on hero card",
      "size": 88,
      "outerStroke": 10,
      "innerStroke": 9,
      "outerColor": "nutrition.primary",
      "innerColor": "fitness.primary",
      "trackOpacity": 0.10,
      "centerText": { "font": "Fraunces", "weight": 600, "fontSize": 15, "italic": false }
    }
  },
  "preview": {
    "description": "Standalone preview HTML wrapper used for design briefs (the body styles outside the phone)",
    "body": {
      "background": "#DDD5C8",
      "padding": "32px 20px 48px",
      "fontFamily": "'Inter','Rubik',sans-serif"
    },
    "label": { "color": "#6A5A4A", "letterSpacing": "0.16em", "textTransform": "uppercase", "fontSize": 10, "fontWeight": 600 },
    "title": { "font": "Instrument Serif", "weight": 400, "fontSize": 24, "color": "ink" },
    "description": { "color": "inkSoft", "fontSize": 12, "lineHeight": 1.5, "maxWidth": 340 }
  },
  "a11y": {
    "minContrast": "AA",
    "verified": {
      "ink_on_canvas":              { "ratio": "12.4:1", "pass": "AAA" },
      "ink_on_surface":             { "ratio": "13.2:1", "pass": "AAA" },
      "inkSoft_on_canvas":          { "ratio": "4.8:1",  "pass": "AA" },
      "white_on_nutritionPrimary":  { "ratio": "4.52:1", "pass": "AA" },
      "white_on_fitnessPrimary":    { "ratio": "5.93:1", "pass": "AA" },
      "white_on_danger":            { "ratio": "4.00:1", "pass": "AA (large/bold text only — 18px+ or 14px bold)" }
    },
    "honorReducedMotion": true
  }
}
