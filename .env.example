# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored (*.local) and must NEVER be committed.

# --- Frontend (safe to expose, bundled into the client) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Admin scripts only (scripts/*.js) — NEVER use in frontend code ---
# This key bypasses Row Level Security. Keep it local; do not deploy it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
